demos/python/.cache

# yasm 1.3.0 assembler -- `setup.py` fetches the release tarball from the
# vendor-deps mirror into src/; the smoke generates derived sources with the
# badc-built python. Only the runner scripts + README are committed.
demos/yasm/*
!demos/yasm/setup.py
!demos/yasm/smoke.py
!demos/yasm/README.md
!demos/yasm/config
!demos/yasm/config/config-posix.h
!demos/yasm/config/tu-list.txt
!demos/yasm/config/libyasm-stdint.h

# edk2 -- badc builds a UEFI app from real EDK II MdePkg sources. `setup.py`
# fetches the MdePkg source subset into src/ from the vendor mirror. Only the
# hand-written AutoGen glue, the app, the boot harness, runner scripts, and
# README are committed.
demos/edk2/*
!demos/edk2/setup.py
!demos/edk2/smoke.py
!demos/edk2/README.md
!demos/edk2/qemu_efi.py
!demos/edk2/AutoGenGlue.c
!demos/edk2/MyApp.c
!demos/edk2/MiniAutoGen.h

# qemu -- QEMU 11.0.2 system emulator. `setup.py` fetches the trimmed source and
# the captured meson build config from the vendor-deps mirror into `.cache/`.
# Only the runner scripts, the badc build shims, and the README are committed.
demos/qemu/*
!demos/qemu/setup.py
!demos/qemu/smoke.py
!demos/qemu/README.md
!demos/qemu/shim/
