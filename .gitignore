/target/
/target-*/
*.exe
*.dll
*.so
*.obj
*.o
.DS_Store
# raylib source -- not committed; `demos/raylib/setup.py` fetches the
# upstream 5.5 tarball into src/ (RGFW backend). The game sources,
# headers, runner scripts and README ARE committed.
demos/raylib/*
!demos/raylib/setup.py
!demos/raylib/smoke.py
!demos/raylib/README.md
!demos/raylib/loderunner.c
!demos/raylib/loderunner_logic.c
!demos/raylib/loderunner.h
!demos/raylib/test_loderunner.c
!demos/raylib/oracle_diff.c
!demos/raylib/include
# SQLite amalgamation -- not committed; `demos/sqlite3/setup.py`
# fetches the upstream tarball and leaves the four .c/.h files
# behind. The build/smoke scripts and the README ARE committed
# (next re-includes).
demos/sqlite3/*
!demos/sqlite3/setup.py
!demos/sqlite3/smoke.py
!demos/sqlite3/README.md
# miniz amalgamation -- same pattern. `setup.py` fetches the
# upstream release zip and drops `miniz.c` / `miniz.h` in
# place; only the runner scripts + driver source are committed.
demos/miniz/*
!demos/miniz/setup.py
!demos/miniz/smoke.py
!demos/miniz/smoke_main.c
!demos/miniz/README.md
# kissfft amalgamation -- same pattern. `setup.py` fetches the
# release zip and drops the six files in place; only the
# runner scripts + driver source are committed.
demos/kissfft/*
!demos/kissfft/setup.py
!demos/kissfft/smoke.py
!demos/kissfft/smoke_main.c
!demos/kissfft/README.md
# bzip2 release tarball -- same pattern. `setup.py` fetches
# the upstream 1.0.8 .tar.gz and drops the library .c/.h files
# in place; only the runner scripts + driver source are
# committed.
demos/bzip2/*
!demos/bzip2/setup.py
!demos/bzip2/smoke.py
!demos/bzip2/smoke_main.c
!demos/bzip2/README.md
# tweetnacl -- the auditable NaCl primitives in two files.
# `setup.py` fetches the upstream pair from the vendor-deps
# release and drops them flat in `demos/tweetnacl/`; only the
# runner scripts + driver source are committed.
demos/tweetnacl/*
!demos/tweetnacl/setup.py
!demos/tweetnacl/smoke.py
!demos/tweetnacl/smoke_main.c
!demos/tweetnacl/README.md
# monocypher -- modern auditable crypto in two files (plus
# optional SHA-512 + Ed25519 module). `setup.py` fetches the
# upstream release tarball from the vendor-deps mirror and
# drops the four sources flat in `demos/monocypher/`.
demos/monocypher/*
!demos/monocypher/setup.py
!demos/monocypher/smoke.py
!demos/monocypher/smoke_main.c
!demos/monocypher/README.md
# bearssl -- TLS stack; first-cut vendoring lands the focused
# hash / MAC / KDF subset, the full smoke is gated on a c5
# const-array aliasing fix tracked separately.
demos/bearssl/*
!demos/bearssl/setup.py
!demos/bearssl/smoke.py
!demos/bearssl/smoke_main.c
!demos/bearssl/README.md
# curl -- vendored by `demos/curl/setup.py` (library sources -> src/,
# public API headers -> include/curl/). Only the hand-written config,
# driver, binding header, runner, and README are committed.
demos/curl/*
!demos/curl/setup.py
!demos/curl/smoke.py
!demos/curl/README.md
!demos/curl/curl_client.c
!demos/curl/curl_config.h
!demos/curl/curl_syslink.h
!demos/curl/_mingw.h
# stb -- a collection of single-file public-domain headers.
# `setup.py` pulls the upstream archive from the vendor-deps
# release and drops a curated set of headers into `demos/stb/`;
# only the runner scripts + driver source are committed.
demos/stb/*
!demos/stb/setup.py
!demos/stb/smoke.py
!demos/stb/smoke_main.c
# chibicc -- Rui Ueyama's small self-hosting C compiler.
# `setup.py` fetches the upstream commit snapshot and drops
# nine `.c` + one header in place; only the runner scripts +
# README are committed.
demos/chibicc/*
!demos/chibicc/setup.py
!demos/chibicc/smoke.py
!demos/chibicc/self_host.py
!demos/chibicc/README.md
# tinycc -- Fabrice Bellard's TCC, multi-TU build for the
# x86_64 / aarch64 backends across ELF / Mach-O / PE.
# `setup.py` fetches the pinned `mob` commit snapshot. Only
# the runner scripts + README are committed; the vendored
# `.c` / `.h` files and the synthesized `config.h` are not.
demos/tinycc/*
!demos/tinycc/setup.py
!demos/tinycc/smoke.py
!demos/tinycc/self_host.py
!demos/tinycc/README.md
# quickjs -- Fabrice Bellard's JavaScript engine. `setup.py`
# fetches the pinned upstream archive from the vendor-deps
# mirror and extracts the qjs sources + the pure-JS test suite;
# only the runner scripts + the REPL-blob stub are committed.
demos/quickjs/*
!demos/quickjs/setup.py
!demos/quickjs/smoke.py
!demos/quickjs/repl_stub.c
!demos/quickjs/README.md
# lua -- Lua 5.5.0 interpreter + the upstream test suite.
# `setup.py` fetches the two pinned tarballs from the
# vendor-deps mirror and extracts the interpreter sources under
# `demos/lua/src/` and the test scripts under `demos/lua/tests/`.
# Only the runner scripts + README are committed.
demos/lua/*
!demos/lua/setup.py
!demos/lua/smoke.py
!demos/lua/README.md
# `setup.py` fetches the pinned TCL source tarball from the
# vendor-deps mirror and extracts it under `demos/tcl/.cache/`.
# Only the runner scripts + README are committed.
demos/tcl/*
!demos/tcl/setup.py
!demos/tcl/smoke.py
!demos/tcl/README.md
# nasm -- NASM 2.16.03 assembler. `setup.py` fetches the pinned release
# tarball from the vendor-deps mirror and extracts the source (with the
# pre-generated instruction tables and the travis/ test suite) under
# `demos/nasm/src/`. Only the runner scripts + README are committed.
demos/nasm/*
!demos/nasm/setup.py
!demos/nasm/smoke.py
!demos/nasm/selfhost.py
!demos/nasm/README.md
!demos/nasm/hexdump.c
!demos/nasm/nasmw.c
!demos/nasm/config
!demos/nasm/config/config-posix.h
!demos/nasm/config/config-windows.h
# Generated by setup.py from the repo-root alarm.ogg payload;
# committed (rather than re-fetched) so the vorbis positive
# decode test has a stable input across CI lanes.
!demos/stb/alarm_ogg.h
