--- a/shell.c	2026-04-09 06:11:49
+++ b/shell.c	2026-05-06 07:07:48
@@ -340,7 +340,24 @@
 #define sqlite3_fgets     fgets
 #define sqlite3_fputs     fputs
 #define sqlite3_fprintf   fprintf
-#define sqlite3_vfprintf  vfprintf
+/* badc/c5 patch: route v?fprintf through a c5-safe wrapper on
+** non-Windows too. Originally `sqlite3_vfprintf` was a macro for
+** libc `vfprintf`, but c5's `va_list` (`long *` walking 16-byte
+** stack slots) is not the platform's va_list (a struct on
+** aarch64 / x86_64), so libc's vfprintf misreads the args. The
+** wrapper routes through `sqlite3_vmprintf` (c5-compiled, so it
+** walks the va_list correctly), then writes via `fputs`.
+*/
+static int sqlite3_vfprintf(FILE *out, const char *zFormat, va_list ap){
+    char *z = sqlite3_vmprintf(zFormat, ap);
+    int rc = 0;
+    if( z ){
+        rc = (int)strlen(z);
+        fputs(z, out);
+        sqlite3_free(z);
+    }
+    return rc;
+}
 #define sqlite3_fsetmode(F,X)   /*no-op*/
 
 #endif
