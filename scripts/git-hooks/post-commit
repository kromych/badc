#!/usr/bin/env python3
"""Regenerate the SSA + asm snapshots after every commit.

Codegen drift relative to the just-finalised commit shows up as
`git status` dirt under `tests/snapshots/`. Fold it into the commit
via `git add tests/snapshots/ && git commit --amend --no-edit`, or
land a follow-up snapshot-only commit.

A `git commit --amend` fired by the user (or by transitive tooling)
also runs this hook; the marker file blocks re-entry so the hook
can't recurse.
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def main() -> int:
    out = subprocess.run(
        ["git", "rev-parse", "--git-path", "SNAPSHOTS_RUNNING"],
        check=True,
        capture_output=True,
        text=True,
    )
    marker = Path(out.stdout.strip())
    if marker.exists():
        return 0
    marker.touch()
    try:
        out = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            check=True,
            capture_output=True,
            text=True,
        )
        root = Path(out.stdout.strip())
        subprocess.run(
            [sys.executable, str(root / "scripts" / "snapshots.py")],
            cwd=root,
            check=False,
            stdout=subprocess.DEVNULL,
        )
        proc = subprocess.run(
            ["git", "diff", "--quiet", "tests/snapshots/"],
            cwd=root,
        )
        if proc.returncode != 0:
            print(
                "\n[post-commit] tests/snapshots/ drift detected. Inspect with:\n"
                "    git diff tests/snapshots/\n"
                "Then fold into the previous commit:\n"
                "    git add tests/snapshots/ && git commit --amend --no-edit\n"
                "or land a follow-up snapshot-only commit."
            )
    finally:
        marker.unlink(missing_ok=True)
    return 0


if __name__ == "__main__":
    sys.exit(main())
