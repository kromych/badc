#!/usr/bin/env python3
"""Pre-push gate: enforce the same fmt + clippy CI job locally.

`cargo fmt --check` and `cargo clippy --release --all-targets -- -D
warnings` run here. A failure aborts the push so a rebase or fix can
land first. Bypass with `git push --no-verify` when shipping a WIP
branch where the strict gate isn't desired.
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def run(label: str, cmd: list[str], cwd: Path) -> int:
    print(f"[pre-push] {label}", flush=True)
    return subprocess.run(cmd, cwd=cwd).returncode


def main() -> int:
    out = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        check=True,
        capture_output=True,
        text=True,
    )
    root = Path(out.stdout.strip())
    rc = run("cargo fmt --check", ["cargo", "fmt", "--check"], root)
    if rc != 0:
        return rc
    return run(
        "cargo clippy --release --all-targets -- -D warnings",
        [
            "cargo",
            "clippy",
            "--release",
            "--all-targets",
            "--",
            "-D",
            "warnings",
        ],
        root,
    )


if __name__ == "__main__":
    sys.exit(main())
